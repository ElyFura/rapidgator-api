{
    "name": "rapidgator-api",
    "version": "1.0.0",
    "description": "Eine vollständige JavaScript-Bibliothek für die RapidGator API v2",
    "main": "index.js",
    "types": "types/index.d.ts",
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:integration": "jest --testPathPattern=integration",
        "test:unit": "jest --testPathIgnorePatterns=integration",
        "build": "npm run build:node && npm run build:browser",
        "build:node": "echo 'Node.js build ready'",
        "build:browser": "browserify index.js -o dist/rapidgator-api.min.js",
        "prepublishOnly": "npm run test:unit",
        "example:basic": "node examples/basic-usage.js",
        "example:upload": "node examples/upload-example.js",
        "lint": "eslint lib/ test/ index.js",
        "dev": "jest --watch --verbose"
    },
    "keywords": [
        "rapidgator",
        "api",
        "file-hosting",
        "upload",
        "download",
        "file-sharing",
        "storage",
        "premium"
    ],
    "author": "ElyFura",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/ElyFura/rapidgator-api.git"
    },
    "bugs": {
        "url": "https://github.com/ElyFura/rapidgator-api/issues"
    },
    "homepage": "https://github.com/ElyFura/rapidgator-api#readme",
    "dependencies": {
        "form-data": "^4.0.4",
        "node-fetch": "^3.3.2"
    },
    "devDependencies": {
        "@types/node": "^20.19.17",
        "browserify": "^17.0.1",
        "jest": "^29.7.0",
        "eslint": "^8.50.0"
    },
    "engines": {
        "node": ">=14.0.0"
    },
    "files": [
        "index.js",
        "lib/",
        "types/",
        "examples/",
        "README.md",
        "LICENSE"
    ],
    "browser": {
        "node-fetch": false,
        "form-data": false
    }
}
